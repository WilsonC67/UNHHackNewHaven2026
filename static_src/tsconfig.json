{
  "compilerOptions": {
    "target": "ESNext",
    "useDefineForClassFields": true,
    "module": "ESNext",
    "lib": ["ESNext", "DOM", "DOM.Iterable"],
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "jsxImportSource": "vue",
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "paths": {
      "@/*": ["./*"],
      "~/*": ["../static/*"]
    }
  },
  "include": ["../env.d.ts", "./**/*", "./**/*.vue", "../global.d.ts"],
  "exclude": ["./**/__tests__/*"]
}
